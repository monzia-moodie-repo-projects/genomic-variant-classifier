# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
# C extensions
*.so
# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
# Virtual environments
venv/
ENV/
env/
.venv/
# IDE settings
.idea/
.vscode/
*.swp
*.swo
*~
# Jupyter Notebook checkpoints
.ipynb_checkpoints/
*.ipynb_checkpoints
# Data files (too large for git)
data/raw/*
data/processed/*
data/external/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/external/.gitkeep
# Model files (too large for git)
models/saved/*
models/checkpoints/*
!models/saved/.gitkeep
!models/checkpoints/.gitkeep
# Logs
logs/*
!logs/.gitkeep
*.log
# Environment variables
.env
.env.local
*.env
# OS files
.DS_Store
Thumbs.db
# Test coverage
.coverage
htmlcov/
.pytest_cache/
# MyPy cache
.mypy_cache/
# Secrets and credentials
*.pem
*.key
credentials.json
secrets.yaml
